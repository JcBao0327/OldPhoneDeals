<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Reset Password - OldPhoneDeals</title>
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>
  <div id="resetVerifiedContainer">
    <h1>Reset password</h1>

    <form id="resetVerifiedForm" class="auth-form" action="" method="POST">
      <label for="passwordInput">New Password</label>
      <input id="passwordInput" name="password" type="password" placeholder="Password" required />

      <label for="confirmPasswordInput">Confirm Password</label>
      <input id="confirmPasswordInput" name="confirmPassword" type="password" placeholder="Confirm password" required />

      <button id="resetPasswordButton" type="submit">Reset password</button>
    </form>
  </div>

  <script src="/js/auth.js"></script>
</body>
</html>