<!-- views/checkout/cart.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Cart - OldPhoneDeals</title>
    <link rel="stylesheet" href="/css/checkOut.css">
</head>
<body>
    <header>
        <button onclick="history.back()">←</button>
        <h2>Cart</h2>
    </header>

    <p>Hi! <%= user.name %></p>
    <p>You has <%= cartItems.length %> items in your cart.</p>
    <% if (unavailableItems.length > 0) { %>
        <p class="warning" style="color: red;">
          The following items are no longer available:
          <%= unavailableItems.map(item => item.title).join(', ') %>
        </p>
      <% } %>
    <main>
        <table>
            <thead>
                <tr>
                    <th>Select</th>
                    <th>Image</th>
                    <th>Title</th>
                    <th>Brand</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody>
                <% if (cartItems.length === 0) { %>
                    <tr>
                        <td colspan="7">Your cart is empty.</td>
                    </tr>
                <% } else { %>
                    <% cartItems.forEach(function(item) { %>
                        <tr class="cart-item <%= item.isAvailable === false ? 'unavailable' : '' %>" data-price="<%= item.price %>">
                            <td>
                                <input
                                    type="checkbox"
                                    name="itemCheckbox"
                                    value="<%= item._id %>"
                                    <%= item.isAvailable === false ? 'disabled' : 'checked' %>
                                >
                            </td>
                            <td><img src="<%= item.image %>" alt="<%= item.title %>" width="60"></td>
                            <td><%= item.title %></td>
                            <td><%= item.brand %></td>
                            <td>$<%= item.price.toFixed(2) %></td>
                            <td>
                                <input
                                    id="quantity-<%= item._id %>"
                                    class="quantity-input"
                                    type="number"
                                    name="quantity"
                                    value="<%= item.quantity %>"
                                    min="0"
                                    data-stock="<%= item.stock %>"
                                    onchange="updateQuantity('<%= item._id %>')"
                                    required
                                >
                            </td>
                            <td>
                                <button type="button" onclick="removeItem('<%= item._id %>')">Remove</button>
                            </td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>

        <section>
            <h2>Total: <span id="total-amount">$<%= totalPrice.toFixed(2) %></span></h2>
        </section>

        <section>
            <% if (cartItems.length > 0) { %>
                <button type="submit" id="checkout-btn" onclick="confirmTransaction()">Check Out</button>
            <% } %>
        </section>
    </main>
    <script src="/js/checkOut.js"></script>
</body>
</html>


